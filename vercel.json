{
  "rewrites": [
    { "source": "/grok",             "destination": "/labs/grok/index.html" },
    { "source": "/grok/",            "destination": "/labs/grok/index.html" },
    { "source": "/grok/:path*",      "destination": "/labs/grok/:path*" },
    { "source": "/chatgpt",          "destination": "/labs/chatgpt/index.html" },
    { "source": "/chatgpt/",         "destination": "/labs/chatgpt/index.html" },
    { "source": "/chatgpt/:path*",   "destination": "/labs/chatgpt/:path*" },
    { "source": "/gemini",           "destination": "/labs/gemini/index.html" },
    { "source": "/gemini/",          "destination": "/labs/gemini/index.html" },
    { "source": "/gemini/:path*",    "destination": "/labs/gemini/:path*" },
    { "source": "/deepseek",         "destination": "/labs/deepseek/index.html" },
    { "source": "/deepseek/",        "destination": "/labs/deepseek/index.html" },
    { "source": "/deepseek/:path*",  "destination": "/labs/deepseek/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cesium.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://cesium.com; img-src 'self' data: blob: https:; connect-src 'self' https: wss:; font-src 'self' data: https://cesium.com; worker-src 'self' blob: https://cesium.com; media-src 'self' blob: https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), autoplay=(self), camera=(self), encrypted-media=(), fullscreen=(self), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(self), payment=(), usb=()"
        }
      ]
    }
  ]
}
